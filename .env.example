APP_NAME="NusaBiz"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=4000
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSL_CA=tidb-ca.pem
MYSQL_ATTR_SSL_CA=tidb-ca.pem

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@nusabiz.id"
MAIL_FROM_NAME="NusaBiz by Wave Project"

# PAYMENT GATEWAY (Midtrans)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# NOTIFICATION (WhatsApp via Fonnte)
FONNTE_TOKEN=

# SHIPPING API (RajaOngkir)
RAJAONGKIR_API_KEY=
RAJAONGKIR_BASE_URL=https://api.rajaongkir.com/starter

VITE_APP_NAME="NusaBiz"
