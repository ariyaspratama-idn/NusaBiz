{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.0"
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|storage|build|assets)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://YOUR_VERCEL_PROJECT_URL.vercel.app",
        "APP_KEY": "base64:YOUR_APP_KEY_HERE",
        "DB_CONNECTION": "mysql",
        "DB_HOST": "YOUR_DB_HOST",
        "DB_PORT": "3306",
        "DB_DATABASE": "YOUR_DB_NAME",
        "DB_USERNAME": "YOUR_DB_USER",
        "DB_PASSWORD": "YOUR_DB_PASSWORD"
    }
}